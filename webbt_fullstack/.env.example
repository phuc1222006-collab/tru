# =========================================================
#  CẤU HÌNH MÔI TRƯỜNG — Website VNVD Full-stack
#  Sao chép file này thành ".env" rồi điền giá trị thật.
# =========================================================

# ----- Kết nối cơ sở dữ liệu MySQL -----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=website_vnpt
# Số kết nối tối đa trong pool
DB_CONNECTION_LIMIT=10

# ----- Bảo mật đăng nhập (JWT) -----
# Chuỗi bí mật ký token — ĐỔI thành chuỗi ngẫu nhiên dài khi chạy thật.
JWT_SECRET=doi_chuoi_bi_mat_nay_thanh_ngau_nhien_that_dai
# Thời hạn token (vd: 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ----- Chatbot AI (Google Gemini) — tùy chọn -----
# Lấy Gemini API key miễn phí tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# ----- Cổng chạy server -----
PORT=3000
